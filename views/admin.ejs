<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDescription %>">
  <meta name="robots" content="noindex">
  <script>(function(){try{var t=localStorage.getItem('rl-theme')||'light';document.documentElement.setAttribute('data-theme',t);}catch(e){}})();</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/fos.css?v=15">
</head>
<body>

<%- include('partials/topbar', { active: 'admin' }) %>

<main class="admin-page" id="adminApp">
  <!-- Login Screen -->
  <div class="admin-login" id="loginScreen">
    <h2>Admin Panel</h2>
    <p>Sign in to manage the Orphil agent platform.</p>
    <div class="form-group">
      <label for="adminPassword">Password</label>
      <input type="password" id="adminPassword" placeholder="Enter admin password" autocomplete="current-password">
    </div>
    <p class="form-error" id="loginError" style="display:none"></p>
    <button class="btn-primary" id="btnLogin">Sign In</button>
  </div>

  <!-- Admin Dashboard (hidden until login) -->
  <div class="admin-container" id="dashboardScreen" style="display:none">
    <h1>Agent Platform</h1>
    <p>Manage agents, knowledge, LLM providers, and platform settings.</p>

    <div class="admin-tabs">
      <button class="admin-tab active" data-tab="agentmgmt">Agent Management</button>
      <button class="admin-tab" data-tab="mcp">MCPs</button>
      <button class="admin-tab" data-tab="llm">LLM Config</button>
      <button class="admin-tab" data-tab="settings">Settings</button>
    </div>

    <!-- Agent Management Tab — per-agent editor (Profile / Knowledge / Memory / MCPs) -->
    <div class="tab-panel active" id="tab-agentmgmt">
      <%- include('partials/agentManager') %>
    </div>

    <!-- MCP Servers Tab -->
    <div class="tab-panel" id="tab-mcp">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
        <h3 style="margin:0;color:var(--text-primary)">MCPs</h3>
        <button class="btn-sm" id="btnAddMcp">+ Add Server</button>
      </div>
      <p style="font-size:13px;color:var(--text-secondary);margin:0 0 20px">External MCP servers provide tools to your agents. Add a server URL, test it, then connect it to one or more agents.</p>
      <div id="mcpList"><p class="empty-state">Loading...</p></div>
    </div>

    <!-- LLM Config Tab -->
    <div class="tab-panel" id="tab-llm">
      <div class="admin-card">
        <h3>Active Model</h3>
        <p class="card-desc">Select the LLM provider and model used for agent responses.</p>
        <div class="form-group">
          <label for="llmProvider">Provider</label>
          <select id="llmProvider"></select>
        </div>
        <div class="form-group">
          <label for="llmModel">Model</label>
          <select id="llmModel"></select>
        </div>
        <button class="btn-primary" id="btnSaveLlm" style="width:auto">Save Model</button>
      </div>

      <div class="admin-card">
        <h3>API Keys</h3>
        <p class="card-desc">Configure API keys for each provider. Keys are encrypted at rest. The <strong>OpenAI</strong> key also powers document embeddings (RAG) and memory recall.</p>
        <div id="apiKeyList"></div>
      </div>
    </div>

    <!-- Settings Tab -->
    <div class="tab-panel" id="tab-settings">
      <div class="admin-card">
        <h3>Platform Settings</h3>
        <p class="card-desc">Additional API keys and configuration.</p>
        <div id="settingsList"></div>
      </div>
    </div>
  </div>

  <!-- MCP Server Modal -->
  <div class="modal-overlay hidden" id="mcpModal">
    <div class="modal">
      <h3 id="mcpModalTitle">Add MCP Server</h3>
      <input type="hidden" id="mcpEditId">
      <div class="form-group">
        <label>Server Name</label>
        <input type="text" id="mcpNameInput" placeholder="e.g. Finney Finance Tools">
      </div>
      <div class="form-group">
        <label>Server URL</label>
        <input type="text" id="mcpUrlInput" placeholder="https://example.com/mcp">
      </div>
      <div class="form-group">
        <label>Bearer Token <span style="font-weight:400;color:var(--text-tertiary)">(optional)</span></label>
        <input type="password" id="mcpTokenInput" placeholder="Auth token if required by the server">
      </div>
      <div id="mcpTestResult" style="display:none;margin-top:4px;padding:10px 12px;background:var(--bg-elevated);border-radius:var(--radius-sm);font-size:12px;line-height:1.5"></div>
      <div class="modal-actions">
        <button class="btn-secondary" id="btnCancelMcp">Cancel</button>
        <button class="btn-secondary" id="btnTestMcpModal">Test Connection</button>
        <button class="btn-primary" id="btnSaveMcp">Save Server</button>
      </div>
    </div>
  </div>

</main>

<link rel="stylesheet" href="/css/admin.css?v=2">
<script src="/js/admin.js"></script>
<script src="/js/theme.js"></script>
</body>
</html>
