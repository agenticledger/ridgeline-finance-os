<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="page-content">
  <section class="hero">
    <div class="container">
      <div class="hero-content fade-in">
        <span class="overline">Product</span>
        <h1>myaiforone</h1>
        <p class="lead">A local AI operating system — a team of specialized AI agents running entirely on your computer, powered by your own AI subscription. Zero platform fees. Full data privacy.</p>
        <div class="hero-actions">
          <a href="<%= links.myaiforone %>" class="btn btn-primary" target="_blank" rel="noopener">Visit myaiforone.com &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- What It Is -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="overline">What It Is</span>
        <h2>Your AI, your machine, your data</h2>
        <p>myaiforone enables individuals and organizations to build and deploy agents, applications, and tools tailored to their specific workflows — without cloud lock-in or per-seat licensing.</p>
      </div>

      <div class="card-grid-3">
        <div class="card">
          <div class="card-icon">&#128274;</div>
          <h3>Full Privacy</h3>
          <p>Everything runs locally on your computer. Your data never touches a third-party platform.</p>
        </div>
        <div class="card">
          <div class="card-icon">&#36;</div>
          <h3>Zero Platform Fees</h3>
          <p>Use your own Claude or ChatGPT subscription. No per-seat licensing. No markup.</p>
        </div>
        <div class="card">
          <div class="card-icon">&#9881;</div>
          <h3>Purpose-Built Agents</h3>
          <p>Agents, applications, and tools tailored to your specific workflows and function.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="overline">Who It's For</span>
        <h2>Two distinct buyers</h2>
      </div>

      <div class="card-grid">
        <div class="card">
          <h3>In-House Finance Teams</h3>
          <p><strong>For the individual:</strong> A personal AI layer — agents that know your close calendar, your reconciliation patterns, your reporting structure.</p>
          <p style="margin-top:16px;"><strong>For the function:</strong> Shared agents and tools across the whole finance team — AP/AR automation, FP&A support, audit prep, executive reporting.</p>
        </div>
        <div class="card">
          <h3>Advisory & Consulting Firms</h3>
          <p><strong>For the individual:</strong> AI that makes each consultant faster — research agents, proposal drafters, client prep tools.</p>
          <p style="margin-top:16px;"><strong>For the practice:</strong> Firm-wide infrastructure — shared knowledge bases, client-facing AI tools, automated deliverables, intake and engagement management.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What You Build -->
  <section>
    <div class="container">
      <div class="belief-block">
        <blockquote>"Build agents, applications, and tools — for any function, any workflow."</blockquote>
      </div>
      <div style="text-align:center;margin-top:32px;">
        <a href="<%= links.myaiforone %>" class="btn btn-primary" target="_blank" rel="noopener">Explore myaiforone &rarr;</a>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
