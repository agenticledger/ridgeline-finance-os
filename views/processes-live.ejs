<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDescription %>">
  <meta name="robots" content="noindex">
  <script>(function(){try{var t=localStorage.getItem('rl-theme')||'light';document.documentElement.setAttribute('data-theme',t);}catch(e){}})();</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/fos.css?v=25">
  <style>
    /* Live Map — scoped. Inherits fos.css theme tokens (--bg/--ink/--accent/...). */
    body.livemap { overflow: hidden; height: 100vh; }
    #lm-stage { position: fixed; top: 56px; left: 0; right: 0; bottom: 0; overflow: hidden; cursor: grab;
      background-image: radial-gradient(circle, var(--dot) 1px, transparent 1px); background-size: 28px 28px; }
    #lm-stage.grabbing { cursor: grabbing; }
    #lm-svg { position: absolute; top: 0; left: 0; transform-origin: 0 0; }
    .lm-edge { fill: none; stroke: var(--line-strong); stroke-width: 1.6; opacity: .5; }
    .lm-edge.live { stroke: var(--accent); opacity: .8; }
    .lm-edge.attention { stroke: var(--warn); opacity: .8; }
    .lm-edge.posted { stroke: var(--good); opacity: .7; }
    .lm-node { cursor: pointer; }
    .lm-box { fill: var(--panel); stroke: var(--line-strong); stroke-width: 1.4; rx: 12; }
    .lm-node.process .lm-box { stroke-width: 1.6; }
    .lm-node.idle .lm-box { stroke: var(--line-strong); }
    .lm-node.live .lm-box { stroke: var(--accent); }
    .lm-node.attention .lm-box { stroke: var(--warn); }
    .lm-node.posted .lm-box { stroke: var(--good); }
    .lm-node.org .lm-box { fill: var(--panel-2); stroke: var(--accent); }
    .lm-node.agent .lm-box { fill: var(--violet-soft); stroke: var(--violet); }
    .lm-title { font-family: var(--sans); font-weight: 700; fill: var(--ink); }
    .lm-sub { font-family: var(--mono); fill: var(--muted); }
    .lm-tag { font-family: var(--mono); font-weight: 600; }
    .lm-node:hover .lm-box { filter: drop-shadow(0 0 10px var(--glow)); }
    .lm-glyph { font-family: var(--sans); font-weight: 800; }
    .lm-go { font-family: var(--mono); fill: var(--muted); opacity: 0; transition: opacity .15s; }
    .lm-node.process:hover .lm-go { opacity: 1; fill: var(--accent); }

    /* Swimlanes (overview) */
    .lm-banner rect { fill: var(--panel-2); stroke: var(--accent); stroke-width: 1.4; }
    .lm-banner-t { font-family: var(--sans); font-weight: 800; font-size: 20px; fill: var(--ink); }
    .lm-banner-s { font-family: var(--mono); font-size: 11px; fill: var(--muted); }
    .lm-lanebg { fill: var(--panel); stroke: var(--line); stroke-width: 1.2; }
    .lm-lanebg.alt { fill: var(--panel-2); }
    .lm-lane.live .lm-lanebg, .lm-lane.attention .lm-lanebg { stroke: var(--line-strong); }
    .lm-lane.empty .lm-lanebg { stroke-dasharray: 5 4; opacity: .7; }
    .lm-lane-t { font-family: var(--sans); font-weight: 700; font-size: 15px; fill: var(--ink); }
    .lm-lane.empty .lm-lane-t { fill: var(--ink-2); }
    .lm-lane-s { font-family: var(--mono); font-size: 11px; fill: var(--muted); }
    .lm-lane-tag { font-family: var(--mono); font-weight: 700; font-size: 9.5px; letter-spacing: .08em; }
    .lm-lanediv { stroke: var(--line); stroke-width: 1; }
    .lm-empty { font-family: var(--mono); font-size: 12px; fill: var(--muted); font-style: italic; }
    .lm-lane.lm-dim { opacity: .14; transition: opacity .2s; }
    /* status dot pulse */
    @keyframes lmpulse { 0%,100% { opacity: 1; } 50% { opacity: .35; } }
    .lm-dot.attention, .lm-dot.live { animation: lmpulse 1.6s ease-in-out infinite; }

    .lm-toolbar { position: fixed; bottom: 18px; left: 18px; display: flex; gap: 6px; z-index: 20; }
    .lm-tbtn { width: 36px; height: 36px; border-radius: 9px; background: var(--panel); border: 1px solid var(--line-strong);
      color: var(--ink-2); cursor: pointer; font-family: var(--mono); font-size: 15px; font-weight: 600; box-shadow: var(--shadow); }
    .lm-tbtn:hover { color: var(--accent); border-color: var(--accent); }
    .lm-legend { position: fixed; bottom: 18px; right: 18px; display: flex; gap: 14px; z-index: 20; padding: 9px 14px;
      border-radius: 11px; background: var(--topbar-bg); backdrop-filter: blur(12px); border: 1px solid var(--line); box-shadow: var(--shadow); }
    .lm-li { display: flex; align-items: center; gap: 6px; font-family: var(--mono); font-size: 11px; color: var(--ink-2); }
    .lm-sw { width: 10px; height: 10px; border-radius: 3px; }

    .viewtoggle { display: inline-flex; border: 1px solid var(--line-strong); border-radius: 9px; overflow: hidden;
      position: fixed; top: 70px; left: 18px; z-index: 20; background: var(--panel); box-shadow: var(--shadow); }
    .viewtoggle a { padding: 6px 14px; font-family: var(--mono); font-size: 12px; font-weight: 600; color: var(--ink-2);
      text-decoration: none; display: flex; align-items: center; gap: 6px; }
    .viewtoggle a.on { background: var(--accent-soft); color: var(--accent-ink); }
    .viewtoggle a + a { border-left: 1px solid var(--line-strong); }
    .viewtoggle svg { width: 14px; height: 14px; }

    /* Schematic node types */
    .lm-node.step .lm-box { fill: var(--panel); stroke: var(--line-strong); stroke-width: 1.6; }
    .lm-node.step.live .lm-box { stroke: var(--accent); }
    .lm-node.step.attention .lm-box { stroke: var(--warn); }
    .lm-node.step.posted .lm-box { stroke: var(--good); }
    .lm-node.policy .lm-box { fill: var(--panel-2); stroke: var(--line); stroke-width: 1.2; }
    .lm-node.tool .lm-box { fill: var(--panel-2); stroke: var(--violet); stroke-width: 1.2; }
    .lm-node.tool.engine .lm-box { stroke: var(--accent); stroke-dasharray: 3 2; }
    /* decision-type accent stripe on step nodes */
    .lm-dt { stroke-width: 4; }
    .lm-dt.policy_based { stroke: var(--accent); }
    .lm-dt.judgment_based { stroke: var(--violet); }
    .lm-dt.mixed { stroke: var(--warn); }
    .lm-gate { fill: var(--warn); stroke: var(--bg); stroke-width: 1.4; }
    .lm-check { fill: none; stroke: var(--warn); stroke-width: 1.6; }
    .lm-railhead { font-family: var(--mono); font-size: 10px; font-weight: 700; fill: var(--muted); letter-spacing: .08em; }

    /* HUD bar (schematic) */
    .lm-hud { position: fixed; top: 66px; left: 50%; transform: translateX(-50%); z-index: 25;
      display: flex; align-items: center; gap: 0; padding: 0; border-radius: 12px;
      background: var(--topbar-bg); backdrop-filter: blur(14px); border: 1px solid var(--line); box-shadow: var(--shadow); overflow: hidden; }
    .lm-hud .seg { padding: 9px 14px; display: flex; flex-direction: column; gap: 2px; border-right: 1px solid var(--line); }
    .lm-hud .seg:last-child { border-right: 0; }
    .lm-hud .k { font-family: var(--mono); font-size: 9px; color: var(--muted); letter-spacing: .08em; text-transform: uppercase; }
    .lm-hud .v { font-family: var(--sans); font-size: 13px; font-weight: 700; color: var(--ink); }
    .lm-hud .v.mono { font-family: var(--mono); }
    .lm-hud .status-pill { font-family: var(--mono); font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 6px; }
    .lm-hud .status-pill.attention { background: var(--warn-soft, rgba(230,160,30,.18)); color: var(--warn); }
    .lm-hud .status-pill.live { background: var(--accent-soft); color: var(--accent-ink); }
    .lm-hud .status-pill.posted { background: var(--good-soft, rgba(40,180,110,.16)); color: var(--good); }
    .lm-hud .status-pill.idle { background: var(--panel-2); color: var(--muted); }

    /* Fast-travel dropdowns */
    .lm-travel { position: fixed; top: 70px; right: 18px; z-index: 25; display: flex; gap: 8px; }
    .lm-travel select { font-family: var(--mono); font-size: 12px; font-weight: 600; color: var(--ink-2);
      background: var(--panel); border: 1px solid var(--line-strong); border-radius: 9px; padding: 7px 10px; cursor: pointer; box-shadow: var(--shadow); }
    .lm-travel select:hover { border-color: var(--accent); color: var(--accent); }
    .lm-back { position: fixed; top: 70px; left: 18px; z-index: 25; font-family: var(--mono); font-size: 12px; font-weight: 600;
      color: var(--ink-2); text-decoration: none; background: var(--panel); border: 1px solid var(--line-strong); border-radius: 9px;
      padding: 7px 12px; box-shadow: var(--shadow); display: inline-flex; align-items: center; gap: 6px; }
    .lm-back:hover { border-color: var(--accent); color: var(--accent); }

    /* Step detail drawer */
    .lm-drawer { position: fixed; top: 56px; right: -460px; width: 440px; bottom: 0; z-index: 40;
      background: var(--topbar-bg); backdrop-filter: blur(16px); border-left: 1px solid var(--line); box-shadow: var(--shadow);
      transition: right .26s cubic-bezier(.2,.7,.2,1); overflow-y: auto; padding: 22px; }
    .lm-drawer.open { right: 0; }
    .lm-drawer h3 { font-family: var(--sans); font-size: 18px; font-weight: 800; color: var(--ink); margin: 0 0 4px; }
    .lm-drawer .dt-tag { display: inline-block; font-family: var(--mono); font-size: 10px; font-weight: 700; padding: 2px 7px;
      border-radius: 6px; background: var(--panel-2); color: var(--ink-2); margin: 0 6px 12px 0; }
    .lm-drawer .sec { margin-top: 18px; }
    .lm-drawer .sec h4 { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
      color: var(--muted); margin: 0 0 8px; }
    .lm-drawer .row { padding: 8px 10px; border: 1px solid var(--line); border-radius: 8px; margin-bottom: 7px; background: var(--panel); }
    .lm-drawer .row .nm { font-family: var(--sans); font-size: 13px; font-weight: 600; color: var(--ink); }
    .lm-drawer .row .meta { font-family: var(--mono); font-size: 11px; color: var(--muted); margin-top: 2px; }
    .lm-drawer pre { font-family: var(--mono); font-size: 11px; color: var(--ink-2); background: var(--panel); border: 1px solid var(--line);
      border-radius: 8px; padding: 10px; overflow-x: auto; margin: 6px 0 0; white-space: pre-wrap; word-break: break-word; }
    .lm-drawer .xclose { position: absolute; top: 16px; right: 18px; cursor: pointer; color: var(--muted); font-family: var(--mono); font-size: 18px; }
    .lm-drawer .xclose:hover { color: var(--ink); }

    #lm-svg { transition: transform .35s cubic-bezier(.2,.7,.2,1); }
    #lm-svg.no-anim { transition: none; }
    .lm-node.lm-dim { opacity: .12; transition: opacity .2s; }
    .lm-edge.lm-dim { opacity: .06; transition: opacity .2s; }
    .lm-order { font-family: var(--mono); font-weight: 700; fill: var(--bg); }
    .lm-orderbg { fill: var(--ink-2); }
    .lm-step-live .lm-orderbg { fill: var(--accent); }
    .lm-step-attention .lm-orderbg { fill: var(--warn); }
    .lm-step-posted .lm-orderbg { fill: var(--good); }
  </style>
</head>
<body class="livemap">

<%- include('partials/topbar', { active: 'processes', org: org }) %>

<% var isSchematic = graph.mode === 'schematic'; %>

<% if (!isSchematic) { %>
<div class="viewtoggle" title="View">
  <a href="/processes"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>Grid</a>
  <a href="/processes/live" class="on"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="12" r="3"/><path d="M9 6h6a3 3 0 0 1 3 3M9 18h6a3 3 0 0 0 3-3"/></svg>Live Map</a>
</div>
<% } else { %>
<a class="lm-back" href="/processes/live"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>Overview</a>
<div class="lm-hud">
  <div class="seg"><span class="k"><%= hud.area || 'Process' %></span><span class="v"><%= hud.name %></span></div>
  <% if (hud.agent) { %><div class="seg"><span class="k">Supervised by</span><span class="v mono"><%= hud.agent %></span></div><% } %>
  <div class="seg"><span class="k">Cadence</span><span class="v mono"><%= hud.frequency %> · <%= hud.mode %></span></div>
  <div class="seg"><span class="k">Steps</span><span class="v mono"><%= hud.steps %></span></div>
  <div class="seg"><span class="k">Latest run<%= hud.period ? ' · ' + hud.period : '' %></span><span class="status-pill <%= hud.signal %>"><%= String(hud.status).toUpperCase() %></span></div>
</div>
<% } %>

<div class="lm-travel">
  <% if (!isSchematic) { %>
  <select id="lm-bu" title="Filter by area">
    <option value="">All areas</option>
    <% nav.forEach(function(g){ %><option value="<%= g.slug %>"><%= g.name %></option><% }) %>
  </select>
  <% } %>
  <select id="lm-proc" title="Jump to process">
    <option value="">Jump to process…</option>
    <% nav.forEach(function(g){ %>
      <optgroup label="<%= g.name %>">
        <% g.processes.forEach(function(pr){ %><option value="<%= pr.slug %>"<%= (current && current.slug === pr.slug) ? ' selected' : '' %>><%= pr.name %></option><% }) %>
      </optgroup>
    <% }) %>
  </select>
</div>

<div id="lm-stage"><svg id="lm-svg" xmlns="http://www.w3.org/2000/svg"></svg></div>

<% if (isSchematic) { %>
<div class="lm-drawer" id="lm-drawer">
  <span class="xclose" onclick="lmCloseDrawer()">×</span>
  <div id="lm-drawer-body"></div>
</div>
<% } %>

<div class="lm-toolbar">
  <button class="lm-tbtn" onclick="lmZoom(1.2)">+</button>
  <button class="lm-tbtn" onclick="lmZoom(0.83)">&minus;</button>
  <button class="lm-tbtn" style="font-size:10px" onclick="lmFit()">FIT</button>
</div>
<div class="lm-legend">
  <% if (isSchematic) { %>
  <span class="lm-li"><span class="lm-sw" style="background:var(--accent)"></span>Policy step</span>
  <span class="lm-li"><span class="lm-sw" style="background:var(--violet)"></span>Judgment / tool</span>
  <span class="lm-li"><span class="lm-sw" style="background:var(--warn)"></span>Gate / checkpoint</span>
  <span class="lm-li"><span class="lm-sw" style="background:var(--good)"></span>Done</span>
  <% } else { %>
  <span class="lm-li"><span class="lm-sw" style="background:var(--accent)"></span>Running</span>
  <span class="lm-li"><span class="lm-sw" style="background:var(--warn)"></span>Needs you</span>
  <span class="lm-li"><span class="lm-sw" style="background:var(--good)"></span>Posted</span>
  <span class="lm-li"><span class="lm-sw" style="background:var(--muted)"></span>Idle</span>
  <% } %>
</div>

<script>window.LM_GRAPH = <%- JSON.stringify(graph) %>;</script>
<script src="/js/processes-live.js?v=4"></script>
<script src="/js/theme.js"></script>
</body>
</html>
