<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="page-content">
  <!-- Services Hero -->
  <section class="hero" style="padding-bottom:60px;">
    <div class="container">
      <div class="hero-content fade-in">
        <span class="overline">Services</span>
        <h1>Strategy. Advisory. <span class="accent">Execution.</span></h1>
        <p class="lead">From AI readiness assessments to deployed agents in production — we meet you where you are and move you forward.</p>
      </div>
    </div>
  </section>

  <!-- Strategy & Planning -->
  <section id="strategy">
    <div class="container">
      <div class="service-block">
        <span class="overline">01</span>
        <h3>Strategy & Planning</h3>
        <p class="service-tagline">Assessment, strategy, resourcing, and roadmap — know where you're going before you build.</p>

        <div class="service-item">
          <h4>AI Training</h4>
          <ul>
            <li>Executive education — AI strategy, opportunity identification, risk awareness</li>
            <li>Staff training — hands-on workflows, prompt craft, tool adoption</li>
            <li>Custom workshops — built around your specific tools, processes, and use cases</li>
          </ul>
          <p class="outcome">&#10003; Outcome: A team that understands AI and can work confidently alongside it</p>
        </div>

        <div class="service-item">
          <h4>AI Transformation Planning & Roadmap</h4>
          <ul>
            <li>Current-state audit — people, processes, tools, data</li>
            <li>Opportunity mapping — where AI creates the most leverage</li>
            <li>Integration roadmap — prioritized initiatives with milestones, owners, and metrics</li>
          </ul>
          <p class="outcome">&#10003; Outcome: A 90-day or 12-month AI roadmap your team can actually execute</p>
        </div>

        <div class="service-item">
          <h4>AI Resourcing & Staff Augmentation</h4>
          <ul>
            <li>Fractional AI leads embedded in your team</li>
            <li>Subject matter experts on specific AI topics (agents, automation, LLMs, compliance)</li>
            <li>Ongoing advisory — answer questions, unblock initiatives, review vendor proposals</li>
          </ul>
          <p class="outcome">&#10003; Outcome: AI expertise available when you need it, without full-time overhead</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Advisory -->
  <section id="advisory">
    <div class="container">
      <div class="service-block">
        <span class="overline">02</span>
        <h3>Advisory</h3>
        <p class="service-tagline">Ongoing expert presence — the AI transformation partner you call when it matters.</p>

        <div class="service-item">
          <h4>Specialist AI Advisory</h4>
          <ul>
            <li>Answering hard questions your team can't answer internally</li>
            <li>Second opinions on AI strategy, tooling choices, and vendor evaluations</li>
            <li>Real-time guidance when AI initiatives hit unexpected walls</li>
          </ul>
          <p class="outcome">&#10003; Outcome: Trusted expert access without the cost of a full-time hire</p>
        </div>

        <div class="service-item">
          <h4>AI Governance & Oversight</h4>
          <ul>
            <li>AI risk and compliance counsel — regulation, audit questions, liability</li>
            <li>Policy and controls — acceptable use, data handling, model governance</li>
            <li>Board and leadership briefings — translating AI into executive language</li>
          </ul>
          <p class="outcome">&#10003; Outcome: AI that is defensible, auditable, and aligned with your obligations</p>
        </div>

        <div class="service-item">
          <h4>Community & Thought Leadership</h4>
          <ul>
            <li>Building and growing your internal AI community</li>
            <li>Positioning your firm as a credible AI voice in your market</li>
            <li>Content, events, and community strategy</li>
          </ul>
          <p class="outcome">&#10003; Outcome: Your firm becomes the go-to AI voice in your space</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Execution -->
  <section id="execution">
    <div class="container">
      <div class="service-block">
        <span class="overline">03</span>
        <h3>Execution</h3>
        <p class="service-tagline">Hands-on delivery — build and run the AI transformation you planned.</p>

        <div class="service-item">
          <h4>AI Transformation Execution</h4>
          <ul>
            <li>Initiative management — running AI projects end-to-end</li>
            <li>Change management — embedding AI into how the team actually works</li>
            <li>Progress tracking — milestones, KPIs, and reporting</li>
          </ul>
          <p class="outcome">&#10003; Outcome: The roadmap gets executed, not just documented</p>
        </div>

        <div class="service-item">
          <h4>AI Agent Development</h4>
          <ul>
            <li>Finance & accounting agents — close process, AP/AR, reporting, reconciliation, audit prep</li>
            <li>Operational agents — intake, triage, research, client communication</li>
            <li>Multi-agent systems — agents that coordinate across tasks and hand off work</li>
          </ul>
          <p class="outcome">&#10003; Outcome: Deployed agents that run real workflows, not demos</p>
        </div>

        <div class="service-item">
          <h4>AI Application Development</h4>
          <ul>
            <li>Client-facing tools — portals, dashboards, AI-assisted reports</li>
            <li>Internal tools — workflow automation, knowledge bases, decision support</li>
            <li>Integrations — connect AI to your existing stack (NetSuite, QuickBooks, FloQast, etc.)</li>
          </ul>
          <p class="outcome">&#10003; Outcome: Production-ready tools your team uses every day</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Delivery Model -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="overline">How We Work</span>
        <h2>Delivery Models</h2>
        <p>Engagements structured to fit your needs — from one-time projects to embedded partnership.</p>
      </div>

      <table class="delivery-table">
        <thead>
          <tr>
            <th>Model</th>
            <th>What it looks like</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>Project</strong></td>
            <td>Fixed scope, defined deliverable, clear end date</td>
          </tr>
          <tr>
            <td><strong>Retainer</strong></td>
            <td>Ongoing monthly engagement — advisory + delivery mixed</td>
          </tr>
          <tr>
            <td><strong>Embedded</strong></td>
            <td>Fractional CAIO presence — attend your meetings, own your AI roadmap</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- CTA -->
  <section style="text-align:center;">
    <div class="container">
      <h2>Let's figure out the right engagement for you.</h2>
      <p style="margin:16px auto 32px;">Every firm is different. Let's talk about yours.</p>
      <a href="/contact" class="btn btn-primary">Start a Conversation &rarr;</a>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
