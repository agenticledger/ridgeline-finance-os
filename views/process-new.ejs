<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDescription %>">
  <meta name="robots" content="noindex">
  <script>(function(){try{var t=localStorage.getItem('rl-theme')||'light';document.documentElement.setAttribute('data-theme',t);}catch(e){}})();</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/fos.css?v=15">
</head>
<body>
<% const orgName = org && org.name ? org.name : org; %>

<header class="topbar"><div class="row">
  <a class="brand" href="/processes"><span class="glyph">R</span><span>Ridgeline Finance OS<small>Mission Control</small></span></a>
  <div class="orgsel" title="Organization (tenant)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v16"/><path d="M19 21V11a2 2 0 0 0-2-2h-2"/><path d="M9 7h2M9 11h2M9 15h2"/></svg>
    <select aria-label="Organization" disabled><option><%= orgName %></option></select>
  </div>
  <a class="navlink" href="/registry">Tools Registry</a>
  <div class="grow"></div>
  <%- include('partials/docsmenu') %>
  <button class="themebtn" type="button" onclick="toggleTheme()" aria-label="Toggle theme">
    <svg class="i-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    <svg class="i-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>
</div></header>

<div class="wsub"><div class="row">
  <a class="wsub-back" href="/processes"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>Processes</a>
  <span class="wsub-sep"></span>
  <span class="wsub-tile new">+</span>
  <div class="wsub-id">
    <h1>New process</h1>
    <p>Define a finance process on the Ridgeline model, then configure and operate it</p>
  </div>
</div></div>

<div class="createwrap">
  <div class="choosewrap" id="chooser">
    <div class="sec-head"><h2>How do you want to build it?</h2><p>Let AI draft the whole process for you, or set it up by hand.</p></div>
    <div class="choosegrid">
      <a class="choosecard ai" href="/automator<%= typeof presetFunctionSlug!=='undefined' && presetFunctionSlug ? ('?function='+presetFunctionSlug) : '' %>">
        <span class="cc-ic ai"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 5.1L19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9L12 3z"/><path d="M19 14l.7 1.9L21.5 16.5l-1.8.6L19 19l-.7-1.9L16.5 16.5l1.8-.6L19 14z"/></svg></span>
        <span class="cc-name">Build with AI</span>
        <span class="cc-desc">Describe the process, or paste the whole case and attach source documents. AI drafts the definition, steps, policies, and tools. You review, then apply.</span>
        <span class="cc-go">Start with AI &rarr;</span>
      </a>
      <button type="button" class="choosecard manual" id="manualPick">
        <span class="cc-ic manual"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg></span>
        <span class="cc-name">Set it up manually</span>
        <span class="cc-desc">Start from a blank skeleton or clone the freight blueprint, then fill in the details, steps, and policies yourself.</span>
        <span class="cc-go">Configure by hand &rarr;</span>
      </button>
    </div>
  </div>

  <form method="POST" action="/process/new" class="newproc" id="createform" hidden>
    <input type="hidden" name="template" id="template" value="blank">
    <input type="hidden" name="functionSlug" value="<%= typeof presetFunctionSlug!=='undefined'?presetFunctionSlug:'' %>">

    <div class="sec-head"><h2>Start from</h2><p>Pick a starting point. You can edit every step and policy afterward in Configure.</p></div>
    <div class="tmplgrid">
      <label class="tmplcard on" data-tmpl="blank">
        <span class="tc-ic accrual"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg></span>
        <span class="tc-name">Blank skeleton</span>
        <span class="tc-desc">Generic 6-step accrual loop: ingest, normalize, compute, gate, post, reconcile. Empty policies to fill in.</span>
      </label>
      <label class="tmplcard" data-tmpl="clone">
        <span class="tc-ic clone"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></span>
        <span class="tc-name">Clone freight blueprint</span>
        <span class="tc-desc">Copy the freight accrual's full step graph, policies, and tool map as a head start for a similar estimation.</span>
      </label>
    </div>

    <div class="sec-head" style="margin-top:8px"><h2>Details</h2><p>Where this process lives and how often it runs.</p></div>
    <div class="card pad">
      <div class="fgrid">
        <label>Process name<input type="text" name="name" required placeholder="e.g. Rebate Accrual"></label>
        <label>Function<input type="text" name="functionName" value="<%= typeof presetFunctionName!=='undefined'?presetFunctionName:'' %>" placeholder="e.g. General Ledger &amp; Close"></label>
        <label>Frequency<select name="frequency"><option value="monthly">Monthly</option><option value="quarterly">Quarterly</option><option value="annual">Annual</option><option value="weekly">Weekly</option></select></label>
        <label>Mode<select name="mode"><option value="manual">Manual</option><option value="auto">Auto</option></select></label>
      </div>
      <label class="full">Description<textarea name="description" rows="2" placeholder="What this process estimates and books."></textarea></label>
    </div>

    <div class="formfoot">
      <button class="btn primary" type="submit">Create process</button>
      <button class="btn ghost" type="button" id="backToOptions">&larr; Back to options</button>
      <span class="sub">Creates a real process (steps + versioned policies). It executes runs once an estimation engine is bound; freight is the first bound engine.</span>
    </div>
  </form>
</div>

<script>
(function(){
  var cards=[].slice.call(document.querySelectorAll('.tmplcard'));
  var input=document.getElementById('template');
  cards.forEach(function(c){
    c.addEventListener('click',function(){
      cards.forEach(function(x){x.classList.remove('on');});
      c.classList.add('on'); input.value=c.dataset.tmpl;
    });
  });
  var chooser=document.getElementById('chooser');
  var form=document.getElementById('createform');
  document.getElementById('manualPick').addEventListener('click',function(){
    chooser.hidden=true; form.hidden=false;
    var nm=form.querySelector('input[name="name"]'); if(nm)nm.focus();
  });
  document.getElementById('backToOptions').addEventListener('click',function(){
    form.hidden=true; chooser.hidden=false;
  });
})();
</script>
<script src="/js/theme.js"></script>
</body>
</html>
