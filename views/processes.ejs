<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDescription %>">
  <meta name="robots" content="noindex">
  <script>(function(){try{var t=localStorage.getItem('rl-theme')||'light';document.documentElement.setAttribute('data-theme',t);}catch(e){}})();</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/fos.css?v=15">
  <style>
    .viewtoggle { display: inline-flex; border: 1px solid var(--line-strong); border-radius: 9px; overflow: hidden; margin-left: 4px; }
    .viewtoggle a { padding: 6px 13px; font-family: var(--mono); font-size: 12px; font-weight: 600; color: var(--ink-2); text-decoration: none; display: flex; align-items: center; gap: 6px; }
    .viewtoggle a.on { background: var(--accent-soft); color: var(--accent-ink); }
    .viewtoggle a + a { border-left: 1px solid var(--line-strong); }
    .viewtoggle svg { width: 14px; height: 14px; }
  </style>
</head>
<body>
<%
  const bound = processes.filter(p=>p.runnable).length;
  const byFn = {};
  processes.forEach(function(p){ const k = p.functionSlug || 'unassigned'; (byFn[k] = byFn[k] || []).push(p); });
  const ic = {
    book:'<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
    'arrow-down':'<line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/>',
    'arrow-up':'<line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/>',
    trend:'<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
    box:'<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>',
    tag:'<path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>',
    wallet:'<path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4z"/>',
    percent:'<line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/>',
    users:'<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
    shield:'<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>'
  };
  function sigLabel(p){
    if(p.signal==='attention') return 'Action needed';
    if(p.signal==='live') return 'Running';
    if(p.signal==='posted') return 'Posted';
    return p.runnable ? 'Ready' : 'Defined';
  }
  const subs = subfunctions;
%>

<header class="topbar"><div class="row">
  <a class="brand" href="/processes"><span class="glyph">R</span><span>Ridgeline Finance OS<small>Command Center</small></span></a>
  <div class="viewtoggle">
    <a href="/processes" class="on"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>Grid</a>
    <a href="/processes/live"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="12" cy="18" r="2"/><path d="M7 6h10M6 8l5 8M18 8l-5 8"/></svg>Live Map</a>
  </div>
  <div class="orgsel" title="Organization (tenant)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v16"/><path d="M19 21V11a2 2 0 0 0-2-2h-2"/><path d="M9 7h2M9 11h2M9 15h2"/></svg>
    <select aria-label="Organization" disabled><option><%= org %></option></select>
  </div>
  <a class="navlink" href="/registry">Tools Registry</a>
  <a class="navlink" href="/agents">Agents</a>
  <div class="grow"></div>
  <span class="statuspill live"><span class="dot"></span><%= bound %> engine-bound &middot; <%= processes.length %> defined</span>
  <%- include('partials/docsmenu') %>
  <button class="themebtn" type="button" onclick="toggleTheme()" aria-label="Toggle theme">
    <svg class="i-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    <svg class="i-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>
</div></header>

<div class="cmdwrap">
  <div class="ctxrow">
    <div class="ctxsel" title="Finance function">
      <span class="ctxlbl">Function</span>
      <select aria-label="Function">
        <option>All functions</option>
        <option selected>Finance</option>
      </select>
    </div>
    <div class="ctxsel" title="Business unit">
      <span class="ctxlbl">Business unit</span>
      <select aria-label="Business unit">
        <option>All business units</option>
        <option selected>Corporate</option>
      </select>
    </div>
    <a class="btn primary cmd-new" href="/process/new">+ New process</a>
  </div>

  <% subs.forEach(function(sf){
       const list = byFn[sf.slug] || [];
       const sigs = {};
       list.forEach(function(p){ sigs[p.signal] = true; });
  %>
    <details class="fnsec" <%= list.length ? 'open' : '' %>>
      <summary>
        <svg class="fnsec-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="fnsec-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><%- ic[sf.icon] || ic.book %></svg></span>
        <div class="fnsec-id">
          <h2><%= sf.name %></h2>
          <p><%= sf.blurb %></p>
        </div>
        <% if(sigs.attention){ %><span class="sig-dot attention" title="Needs attention"></span><% } %>
        <% if(sigs.live){ %><span class="sig-dot live" title="Running"></span><% } %>
        <% if(sigs.posted){ %><span class="sig-dot posted" title="Posted"></span><% } %>
        <span class="fnsec-count"><%= list.length %></span>
        <a class="fnsec-add" href="/process/new?function=<%= sf.slug %>" title="Add a process to <%= sf.name %>">+ Add</a>
      </summary>
      <div class="fnsec-body">
        <% if(list.length){ %>
          <div class="procgrid">
            <% list.forEach(function(p){ %>
              <div class="proctile <%= p.signal %>">
                <div class="pt-top">
                  <span class="pt-glyph"><%= p.name.slice(0,1).toUpperCase() %></span>
                  <span class="pt-sig <%= p.signal %>"><span class="d"></span><%= sigLabel(p) %></span>
                </div>
                <div class="pt-name"><%= p.name %></div>
                <div class="pt-meta">
                  <span><b><%= p.stepCount %></b> steps</span>
                  <span><b><%= p.runCount %></b> runs</span>
                  <span style="text-transform:capitalize"><%= p.frequency %> &middot; <%= p.mode %></span>
                </div>
                <div class="pt-acts">
                  <a class="tact" href="/process/<%= p.slug %>/setup?section=overview"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>Configure</a>
                  <a class="tact <%= p.runnable?'go':'' %>" href="/process/<%= p.slug %>/monitor"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Manage</a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <a class="fnempty" href="/process/new?function=<%= sf.slug %>">
            <span class="fe-plus">+</span>
            <span>No processes yet. <b>Define one</b> on the Finance OS model.</span>
          </a>
        <% } %>
      </div>
    </details>
  <% }) %>

  <% if(byFn.unassigned){ %>
    <details class="fnsec" open>
      <summary>
        <svg class="fnsec-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="fnsec-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></span>
        <div class="fnsec-id"><h2>Unassigned</h2><p>Processes not yet homed to a sub-function.</p></div>
        <span class="fnsec-count"><%= byFn.unassigned.length %></span>
      </summary>
      <div class="fnsec-body">
        <div class="procgrid">
          <% byFn.unassigned.forEach(function(p){ %>
            <div class="proctile <%= p.signal %>">
              <div class="pt-top"><span class="pt-glyph"><%= p.name.slice(0,1).toUpperCase() %></span><span class="pt-sig <%= p.signal %>"><span class="d"></span><%= sigLabel(p) %></span></div>
              <div class="pt-name"><%= p.name %></div>
              <div class="pt-meta"><span><b><%= p.stepCount %></b> steps</span><span><b><%= p.runCount %></b> runs</span><span style="text-transform:capitalize"><%= p.frequency %> &middot; <%= p.mode %></span></div>
              <div class="pt-acts">
                <a class="tact" href="/process/<%= p.slug %>/setup?section=overview">Configure</a>
                <a class="tact" href="/process/<%= p.slug %>/monitor">Manage</a>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </details>
  <% } %>
</div>
<script src="/js/theme.js"></script>
</body>
</html>
