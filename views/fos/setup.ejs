<!-- Setup — READ-ONLY package inspection. Editing is agentic-only (decision §14.8):
     the process spine (steps, engines, policies, tools) is created and modified only
     through the owner agent. This tab inspects the persisted package; the "Ask the
     owner agent" prompts route changes through the chat dock + the fos__ Builder tools. -->
<%
  const decLabel = { policy_based:'Policy', judgment_based:'Judgment', mixed:'Mixed' };
  const toolTypeLabel = { automation:'Automation', skill:'Skill', agent:'Agent', prompt:'Prompt', mcp:'Integration', human:'Human' };
  const it = proc.improveTrigger || {};
  const agentName = (typeof ownerAgent !== 'undefined' && ownerAgent) ? ownerAgent.name : 'the owner agent';
%>

<div class="ro-note">
  <span class="ro-ic">&#9632;</span>
  <span>This package is <b>read-only</b> here. Steps, engines, and policies are created and changed only by <b><%= agentName %></b>. Open the chat dock to ask the agent to modify the package, it uses its Builder tools and re-renders the result.</span>
</div>

<% if(section==='steps'){ %>
  <section class="setupsec">
    <div class="sec-head">
      <h2>Steps</h2>
      <p><b><%= proc.steps.length %></b> steps. The ordered checklist the agent runs each period, wired as a DAG. Each step lists the steps it depends on, the engine that computes it, the tools it runs on, and the policies it applies. Gated steps pause for a human before the run continues.</p>
    </div>

    <div class="steplist">
      <% proc.steps.forEach(function(s){ var deps=(s.dependsOn||[]); %>
      <div class="stepcard <%= s.isGate?'gate':'' %>">
        <div class="sc-main">
          <div class="sc-top">
            <div class="sc-num"><%= s.order %></div>
            <div class="sc-id">
              <div class="sc-name-ro"><%= s.name %><% if(s.isGate){ %> <span class="chip awaiting_human">gate</span><% } %><% if(s.pauseAfter){ %> <span class="chip pending">pauses</span><% } %></div>
              <div class="sc-meta">
                <span class="chip <%= s.decisionType %>"><%= decLabel[s.decisionType]||s.decisionType %></span>
                <span class="sc-ver">v<%= s.version %></span>
                <% if(s.engineSource){ %><code class="sc-eng"><%= s.engineSource %></code><% } else { %><span class="sc-none">scaffold</span><% } %>
              </div>
            </div>
          </div>
          <% if(s.description){ %><p class="sc-desc"><%= s.description %></p><% } %>
          <div class="sc-wire">
            <span><span class="rl">Depends on</span><% if(deps.length){ %><%= deps.join(', ') %><% } else { %><i>nothing (entry step)</i><% } %></span>
            <% if(s.feedbackTo){ %><span><span class="rl">Proposes changes to</span><%= s.feedbackTo %></span><% } %>
          </div>
        </div>

        <div class="sc-panels">
          <div class="sc-panel">
            <div class="sc-ph"><span class="sc-pt">Tools</span><span class="sc-pc"><%= (s.tools||[]).length %></span></div>
            <div class="sc-chips">
              <% (s.tools||[]).forEach(function(t){ %>
                <span class="toolchip <%= t.type %>">
                  <span class="tc-ty"><%= toolTypeLabel[t.type]||t.type %></span>
                  <span class="tc-nm"><%= t.name %></span>
                  <% if(t.role==='engine'){ %><span class="tc-rl">engine</span><% } %>
                </span>
              <% }) %>
              <% if(!(s.tools||[]).length){ %><span class="sc-none">No tools attached.</span><% } %>
            </div>
          </div>

          <div class="sc-panel">
            <div class="sc-ph"><span class="sc-pt">Policies</span><span class="sc-pc"><%= (s.policies||[]).length %></span></div>
            <div class="sc-pols">
              <% (s.policies||[]).forEach(function(p){ var keys=Object.keys(p.params||{}); %>
                <div class="polmini">
                  <div class="pm-h"><span class="pm-nm"><%= p.name %></span><span class="pm-v">v<%= p.version %></span></div>
                  <% if(p.definition){ %><p class="pm-def-ro"><%= p.definition %></p><% } %>
                  <% if(keys.length){ %>
                    <div class="pm-params">
                      <% keys.forEach(function(k){ %>
                        <span class="pm-param-ro"><span class="pmk"><%= k %></span><b><%= p.params[k]===''?'—':p.params[k] %></b></span>
                      <% }) %>
                    </div>
                  <% } %>
                </div>
              <% }) %>
              <% if(!(s.policies||[]).length){ %><span class="sc-none">No policies on this step.</span><% } %>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
      <% if(!proc.steps.length){ %><p class="cfg-empty">No steps defined yet. Ask <%= agentName %> to build the package.</p><% } %>
    </div>

    <% if(proc.policies && proc.policies.length){ %>
    <div class="sec-head" style="margin-top:26px"><h2 style="font-size:15px">Process-scope policies</h2><p>Policies not pinned to a single step. They apply across the whole process.</p></div>
    <div class="sc-pols wide">
      <% proc.policies.forEach(function(p){ var keys=Object.keys(p.params||{}); %>
        <div class="polmini">
          <div class="pm-h"><span class="pm-nm"><%= p.name %></span><span class="pm-v">v<%= p.version %></span></div>
          <% if(p.definition){ %><p class="pm-def-ro"><%= p.definition %></p><% } %>
          <% if(keys.length){ %>
            <div class="pm-params">
              <% keys.forEach(function(k){ %><span class="pm-param-ro"><span class="pmk"><%= k %></span><b><%= p.params[k]===''?'—':p.params[k] %></b></span><% }) %>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
    <% } %>
  </section>

<% } else { /* Definition (default) — identity + improvement, read-only */
     var curFn = proc.function ? proc.function.name : 'Unassigned';
%>
  <section class="setupsec">
    <div class="sec-head">
      <h2>Definition</h2>
      <p>The identity, placement and cadence of this process. Set when the owner agent created the package.</p>
    </div>
    <div class="cfg-readonly grid2">
      <span><span class="rl">Process name</span><b><%= proc.name %></b></span>
      <span><span class="rl">Sub-function</span><b><%= curFn %></b></span>
      <span><span class="rl">Organization</span><b><%= proc.org.name %></b></span>
      <span><span class="rl">Legal entity</span><b><%= proc.legalEntity ? proc.legalEntity.name : '—' %></b></span>
      <span><span class="rl">Business unit</span><b><%= proc.businessUnit ? proc.businessUnit.name : 'None' %></b></span>
      <span><span class="rl">Frequency</span><b><%= proc.frequency.charAt(0).toUpperCase()+proc.frequency.slice(1) %></b></span>
      <span><span class="rl">Run mode</span><b><%= String(proc.mode).charAt(0).toUpperCase()+String(proc.mode).slice(1) %></b></span>
      <span><span class="rl">Package version</span><b>v<%= proc.version %></b></span>
    </div>
    <% if(proc.description){ %><p class="sc-desc" style="margin-top:14px"><%= proc.description %></p><% } %>
  </section>

  <section class="setupsec">
    <div class="sec-head">
      <h2>Improvement</h2>
      <p>How the self-review loop runs. When triggered, the Improvement Agent ingests the last N runs, reconciles booked vs actual, and proposes parameter changes for review.</p>
    </div>
    <div class="cfg-readonly grid2">
      <span><span class="rl">Trigger mode</span><b><%= (it.mode||'auto').charAt(0).toUpperCase()+(it.mode||'auto').slice(1) %></b></span>
      <span><span class="rl">Runs ingested per cycle</span><b><%= it.lookbackRuns||6 %></b></span>
    </div>
  </section>
<% } %>
