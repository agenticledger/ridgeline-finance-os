<!-- Improve — the closed loop. Reconcile booked vs actual, regrade, propose + apply policy changes (versioned). -->
<%
  const cov = learn.coverage || {pct:0,hits:0,total:0};
  const mae = learn.maeByCarrier || {};
  const recon = s.reconciliation || null;
  const props = proposals || [];
  const vers = versions || [];
  const slug = proc.slug;
  const runId = run ? run.id : '';
  const canReconcile = run && (run.status === 'posted' || run.status === 'reconciled' || run.frozen);
  const riskColor = {low:'var(--good)',medium:'var(--warn)',high:'var(--bad)'};
  const statusChip = {pending:'review', applied:'auto_post', dismissed:'escalate'};
%>

<section class="card">
  <div class="card-h"><h3>Self-review &mdash; forward replay</h3><span class="sub">no look-ahead &middot; <%= learn.monthsReplayed||0 %> cycles scored</span></div>
  <div class="card-b">
    <div class="metricbig">
      <div class="m"><div class="v"><%= cov.pct||0 %>%</div><div class="l">90% band coverage <span style="color:var(--muted)">(<%= cov.hits %>/<%= cov.total %> actuals in band)</span></div></div>
      <div class="m"><div class="v"><%= learn.monthsReplayed||0 %></div><div class="l">months replayed</div></div>
      <div class="m"><div class="v"><%= props.length %></div><div class="l">live proposals</div></div>
    </div>
    <div class="note-card" style="margin-top:18px">
      <b>Improve tunes the methodology, not the numbers.</b> The realization factor is recomputed from data every run. What the loop changes is a <b>policy parameter</b> (e.g. the mix-shift z-threshold or the baseline window). The next run recomputes every derived value under the new params, on future runs only.
    </div>
  </div>
</section>

<!-- ── Reconciliation: booked vs the actuals that landed after close ── -->
<section class="card">
  <div class="card-h">
    <h3>Reconciliation &mdash; booked vs actual</h3>
    <span class="sub"><%= recon ? ('reconciled ' + recon.period) : 'post-close actuals' %></span>
  </div>
  <div class="card-b">
    <% if (recon) { %>
      <table class="grid">
        <thead><tr><th>Carrier</th><th class="num">Booked</th><th class="num">Actual</th><th class="num">Variance</th><th class="num">%</th><th>In band</th></tr></thead>
        <tbody>
          <% recon.carriers.forEach(function(c){ %>
          <tr>
            <td class="carrier"><%= c.label %></td>
            <td class="num"><%= fmt0(c.estimated) %></td>
            <td class="num" style="font-weight:700"><%= fmt0(c.actual) %></td>
            <td class="num" style="color:<%= Math.abs(c.variance)>recon.materiality?'var(--bad)':'var(--ink-2)' %>"><%= signed(c.variance) %></td>
            <td class="num"><%= (c.variancePct>=0?'+':'') + c.variancePct %>%</td>
            <td><span class="chip <%= c.inBand?'auto_post':'escalate' %>"><%= c.inBand?'in 90% band':'outside band' %></span></td>
          </tr>
          <% }) %>
          <tr style="border-top:2px solid var(--line-strong);font-weight:700">
            <td>Portfolio</td>
            <td class="num"><%= fmt0(recon.estTotal) %></td>
            <td class="num"><%= fmt0(recon.actTotal) %></td>
            <td class="num" style="color:<%= recon.withinMateriality?'var(--good)':'var(--bad)' %>"><%= signed(recon.totalVariance) %></td>
            <td class="num"><%= (recon.totalVariancePct>=0?'+':'') + recon.totalVariancePct %>%</td>
            <td><span class="chip <%= recon.withinMateriality?'auto_post':'escalate' %>"><%= recon.withinMateriality?'within materiality':'true-up' %></span></td>
          </tr>
        </tbody>
      </table>
      <% if (recon.trueUp) { %>
        <div class="note-card" style="margin-top:16px;border-color:var(--bad)">
          <b>True-up staged (<%= recon.trueUp.direction %>).</b> <%= recon.trueUp.memo %>
          <div style="margin-top:8px;font-family:var(--mono,monospace);font-size:13px">
            <% recon.trueUp.lines.forEach(function(l){ %>
              <div><%= l.account %> &nbsp; Dr <%= fmt0(l.debit) %> &nbsp; Cr <%= fmt0(l.credit) %></div>
            <% }) %>
          </div>
        </div>
      <% } else { %>
        <div class="note-card" style="margin-top:16px">
          <b>Within materiality (<%= fmt0(recon.materiality) %>).</b> Portfolio variance <%= signed(recon.totalVariance) %> needs no true-up. The estimate held.
        </div>
      <% } %>
    <% } else { %>
      <p class="hint" style="margin:0 0 12px">When the invoices for this period arrive, reconcile the booked accrual against the real invoiced totals. This writes immutable per-carrier variance rows and stages a true-up JE if the portfolio breaches materiality.</p>
      <% if (canReconcile) { %>
        <form method="POST" action="/run/<%= runId %>/reconcile" class="btn-row" style="margin:0">
          <input type="hidden" name="slug" value="<%= slug %>">
          <button class="btn primary" type="submit">Reconcile against actuals</button>
        </form>
      <% } else { %>
        <p class="hint" style="margin:0;color:var(--muted)">Reconciliation unlocks once the run is posted or frozen.</p>
      <% } %>
    <% } %>
  </div>
</section>

<section class="card">
  <div class="card-h"><h3>Backtest accuracy &mdash; engine vs Denise</h3><span class="sub">mean absolute error, lower is better</span></div>
  <table class="grid">
    <thead><tr><th>Carrier</th><th class="num">This engine MAE</th><th class="num">Denise MAE</th><th>Result</th></tr></thead>
    <tbody>
      <% ['peak','heartland','coastal'].forEach(function(c){ var m=mae[c]; if(!m)return; var better=m.engine<m.denise; %>
      <tr>
        <td class="carrier" style="text-transform:capitalize"><%= c %></td>
        <td class="num" style="font-weight:700"><%= fmt0(m.engine) %></td>
        <td class="num"><%= fmt0(m.denise) %></td>
        <td><span class="chip <%= better?'auto_post':'escalate' %>"><%= better?'beats baseline':'review' %></span></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<!-- ── Proposals: concrete, param-targeted, one-click apply (versioned) ── -->
<section class="card">
  <div class="card-h">
    <h3>Improvement proposals</h3>
    <span class="sub">Policy levers &middot; apply = new version, future runs only</span>
  </div>
  <div class="card-b">
    <% if (!props.length) { %>
      <p class="hint" style="margin:0 0 12px">No proposals yet. Generate them from the forward-replay diagnostics.</p>
    <% } else { %>
      <div class="proplist">
        <% props.forEach(function(p){ var t=p.target||{}; var applyable = p.status==='pending' && t.policyKey && t.param; %>
        <div class="propcard">
          <div class="prop-head">
            <span class="chip <%= statusChip[p.status]||'review' %>"><%= p.status %></span>
            <span class="prop-comp"><%= p.lever %> &middot; <%= p.component %></span>
            <span class="prop-risk" style="color:<%= riskColor[p.riskLevel]||'var(--ink-2)' %>"><%= p.riskLevel %> risk</span>
          </div>
          <div class="prop-diag"><%= p.diagnosis %></div>
          <div class="prop-prop"><b>Proposal:</b> <%= p.proposal %></div>
          <% if (t.policyKey) { %>
            <div class="prop-target"><code><%= t.policyKey %>.<%= t.param %></code>: <%= t.from %> &rarr; <strong><%= t.to %></strong></div>
          <% } %>
          <div class="prop-act">
            <% if (applyable) { %>
              <form method="POST" action="/improve/proposal/<%= p.id %>/apply" style="margin:0">
                <input type="hidden" name="slug" value="<%= slug %>">
                <input type="hidden" name="run" value="<%= runId %>">
                <button class="btn primary btn-sm" type="submit">Approve &amp; apply</button>
              </form>
            <% } else if (p.status==='applied') { %>
              <span class="hint" style="color:var(--good)">Applied &mdash; see version history below.</span>
            <% } else { %>
              <span class="hint">Advisory (methodology) &mdash; needs an engine change, not a param.</span>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>
    <% } %>
    <form method="POST" action="/process/<%= slug %>/improve/propose" class="btn-row" style="border-top:1px solid var(--line-2);margin-top:14px;padding:14px 0 0">
      <input type="hidden" name="run" value="<%= runId %>">
      <button class="btn" type="submit"><%= props.length ? 'Regenerate proposals' : 'Generate proposals' %></button>
      <span class="hint">In production the overseer approves in chat ("apply 1 and 3, skip 2"); the Improvement Agent applies each as a new policy version.</span>
    </form>
  </div>
</section>

<!-- ── Version history: the audit trail of every Improve action ── -->
<% if (vers.length) { %>
<section class="card">
  <div class="card-h"><h3>Policy version history</h3><span class="sub">immutable ObjectVersion audit &middot; <%= vers.length %> change<%= vers.length===1?'':'s' %></span></div>
  <table class="grid">
    <thead><tr><th>Policy</th><th>Change</th><th class="num">Version</th><th>Source</th><th>Approved by</th><th>When</th></tr></thead>
    <tbody>
      <% vers.forEach(function(v){ var d=v.diff||{}; %>
      <tr>
        <td><%= v.policyName %></td>
        <td><code><%= d.param %></code>: <%= d.before %> &rarr; <strong><%= d.after %></strong></td>
        <td class="num">v<%= v.version %></td>
        <td><span class="chip auto_post"><%= v.source %></span></td>
        <td><%= v.approvedBy || '--' %></td>
        <td><%= v.approvedAt ? new Date(v.approvedAt).toLocaleString('en-US',{month:'short',day:'numeric',hour:'numeric',minute:'2-digit'}) : '--' %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<% } %>
