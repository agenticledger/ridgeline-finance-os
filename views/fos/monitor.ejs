<!-- Monitor — the overseer's check-in. Review, decide, sign. -->

<!-- Hero status -->
<section class="card hero">
  <div class="lead">
    <span class="state <%= heroState %>"><%= heroLabel %></span>
    <h1><%= heroTitle %></h1>
    <p class="ctx"><%= proc.description %></p>
    <div class="meta">
      <span><b>Period</b> <%= s.period %></span>
      <span><b>Run</b> <%= runTime %></span>
      <span><b>Mode</b> <%= run.mode %></span>
      <span><b>Shipments</b> <%= (run.lines||[]).length %></span>
      <% if(frozen){ %><span class="chip frozen">Frozen for close</span><% } %>
    </div>
  </div>
  <div class="figure">
    <div class="lab">Booked accrual</div>
    <div class="big"><%= fmt0(s.point) %></div>
    <div class="band">90% band <%= fmt0(s.low) %> &ndash; <%= fmt0(s.high) %></div>
    <% if(s.vsDenise!=null){ var win = Math.abs(s.point - s.denise); %>
      <div class="delta <%= 'win' %>"><%= signed(s.vsDenise) %> vs Denise\u2019s trailing-average (<%= fmt0(s.denise) %>)</div>
    <% } %>
  </div>
</section>

<!-- KPI strip -->
<section class="kpis">
  <div class="kpi"><div class="lab">Contract baseline [D]</div><div class="val"><%= fmt0(s.contractual) %></div><div class="note">Pure rate-card math, every lane</div></div>
  <div class="kpi"><div class="lab">Realization adj. [A]</div><div class="val"><%= signed(s.point - s.contractual) %></div><div class="note">Learned factor + ensemble blend</div></div>
  <div class="kpi"><div class="lab">Confidence band</div><div class="val">&plusmn;<%= fmt0((s.high - s.low)/2) %></div><div class="note"><%= pct(((s.high-s.low)/2)/s.point) %> of booked, 90% level</div></div>
  <div class="kpi"><div class="lab">Gate dispositions</div><div class="val"><%= (ctrl.dispositions&&ctrl.dispositions.escalate)||0 %>/<%= carriers.length %></div><div class="note">escalate &middot; <%= (ctrl.dispositions&&ctrl.dispositions.auto_post)||0 %> auto-post</div></div>
</section>

<!-- Action items + sign-off -->
<section class="card actions">
  <div class="card-h"><h3>Action items</h3><span class="sub"><%= queue.length %> awaiting the overseer</span></div>
  <% if(queue.length){ queue.forEach(function(q){ %>
    <div class="item">
      <span class="sev <%= q.severity %>"></span>
      <div class="body"><div class="t"><%= q.label %></div><div class="d"><%= q.detail %></div></div>
      <div class="amt"><%= q.dollar!=null?fmt0(q.dollar):'' %></div>
    </div>
  <% }) } else { %>
    <div class="item"><span class="sev info"></span><div class="body"><div class="t">Nothing needs you.</div><div class="d">Every carrier cleared the materiality &times; confidence gate and auto-posted.</div></div></div>
  <% } %>
  <div class="btn-row">
    <% if(st==='awaiting_human'||st==='needs_review'){ %>
      <form method="POST" action="/run/<%= run.id %>/signoff" style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
        <input type="hidden" name="slug" value="<%= proc.slug %>">
        <input type="hidden" name="actor" value="M. Chen (Controller)">
        <input type="text" name="note" placeholder="Sign-off note (optional)" style="font-family:var(--sans);font-size:13px;padding:9px 12px;border:1px solid var(--line);border-radius:9px;min-width:240px">
        <button class="btn primary" type="submit">Sign off &amp; post JE &rarr;</button>
      </form>
      <span class="hint">Signing posts the staged journal entry and advances the run.</span>
    <% } else if(st==='posted' && !frozen){ %>
      <form method="POST" action="/run/<%= run.id %>/freeze"><input type="hidden" name="slug" value="<%= proc.slug %>"><button class="btn">Freeze for period close</button></form>
      <span class="hint">Posted by <%= (summary.postedBy)||'Controller' %>. Freeze to lock immutable.</span>
    <% } else if(frozen){ %>
      <span class="chip frozen">Run frozen &mdash; immutable system of record</span>
    <% } %>
    <form method="POST" action="/process/<%= proc.slug %>/run" style="margin-left:auto"><button class="btn ghost">Re-run accrual</button></form>
  </div>
</section>

<!-- Outcomes: per-carrier with confidence band -->
<section class="card">
  <div class="card-h"><h3>Outcomes by carrier</h3><span class="sub">point estimate, 90% band, gate decision</span></div>
  <table class="grid">
    <thead><tr>
      <th>Carrier</th><th class="num">Contract [D]</th><th class="num">Factor</th><th class="num">Booked</th>
      <th class="bandcell">90% band &middot; <span style="color:var(--bad)">|</span> Denise</th><th class="num">CV</th><th>Gate</th><th class="num">vs Denise</th>
    </tr></thead>
    <tbody>
    <% carriers.forEach(function(c){ var b=band(c); %>
      <tr>
        <td class="carrier"><%= c.label %><small><%= c.region %></small></td>
        <td class="num"><%= fmt0(c.contractual) %></td>
        <td class="num"><%= c.factor.toFixed(3) %></td>
        <td class="num" style="font-weight:700"><%= fmt0(c.point) %></td>
        <td class="bandcell">
          <div class="bandtrack">
            <div class="bandfill" style="left:<%= b.lo %>%;width:<%= Math.max(2,b.hi-b.lo) %>%"></div>
            <div class="bandpt" style="left:<%= b.pt %>%"></div>
            <% if(b.den!=null){ %><div class="bandden" style="left:<%= b.den %>%"></div><% } %>
          </div>
          <div class="bandcap"><span><%= fmt0(c.low) %></span><span><%= fmt0(c.high) %></span></div>
        </td>
        <td class="num"><%= pct(c.cv) %></td>
        <td><span class="chip <%= c.decision %>"><%= decLabel[c.decision] %></span></td>
        <td class="num <%= (c.vsDenise>=0?'':'') %>" style="font-weight:600"><%= signed(c.vsDenise) %></td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</section>

<div class="split2">
  <!-- Journal entry preview -->
  <section class="card">
    <div class="card-h"><h3>Journal entry</h3><span class="sub"><%= st==='posted'?'posted':'staged' %> &middot; <%= s.je && s.je.date %></span></div>
    <div class="card-b je">
      <% (s.je&&s.je.lines||[]).forEach(function(l){ %>
        <div class="jrow"><div><span class="acct"><%= l.account %></span><div class="sub"><%= l.subledger %></div></div>
          <div class="dr"><%= l.debit?fmt2(l.debit):'' %></div><div class="cr"><%= l.credit?fmt2(l.credit):'' %></div></div>
      <% }) %>
      <div class="jrow tot"><div>Balanced</div><div class="dr"><%= fmt2(s.je&&s.je.total) %></div><div class="cr"><%= fmt2(s.je&&s.je.total) %></div></div>
    </div>
  </section>

  <!-- Judgments: policy vs judgment -->
  <section class="card">
    <div class="card-h"><h3>Where rules end &amp; judgment begins</h3><span class="sub">auditability</span></div>
    <div class="card-b">
      <ul class="list-clean">
        <li><span class="ic" style="background:#5a6373"></span><div><b>Deterministic [D]</b> &mdash; pricing, fuel, accessorials, floors, zone/territory, the materiality gate. <%= fmt0(s.contractual) %> of contract math, fully rule-based.</div></li>
        <li><span class="ic" style="background:#6b46c9"></span><div><b>Judgment [A]</b> &mdash; the realization factor (learned from <%= (s.calibration&&s.calibration.peak&&s.calibration.peak.n)||'6mo' %> invoice lines), the inverse-variance ensemble, and the confidence band. <%= signed(s.point - s.contractual) %> of adjustment.</div></li>
        <li><span class="ic" style="background:#0f9d6e"></span><div><b>Human [H]</b> &mdash; sign-off on the <%= (ctrl.dispositions&&ctrl.dispositions.escalate)||0 %> escalations before the JE posts. The overseer signs the exceptions, not the routine.</div></li>
      </ul>
    </div>
  </section>
</div>
