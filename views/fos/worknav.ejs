<!-- Per-process workspace sidebar: OPERATE (run lifecycle) + CONFIGURE (setup). -->
<%
  const opItems = [
    { tab:'monitor', label:'Overview',  icon:'gauge' },
    { tab:'execute', label:'Execute',   icon:'play' },
    { tab:'flow',    label:'Flow',      icon:'flow' },
    { tab:'history', label:'History',   icon:'history' },
  ];
  // Configure items: 'sec' entries link to /setup?section=, 'tab' entries link to /process/:slug/:tab.
  const cfgItems = [
    { sec:'overview',  label:'Definition',  icon:'doc' },
    { sec:'steps',     label:'Steps',       icon:'list' },
    { tab:'edit',      label:'Edit',        icon:'sliders' },
  ];
  const inConfigure = (active==='setup' || active==='edit');
  const ic = {
    gauge:'<path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/>',
    play:'<polygon points="6 4 20 12 6 20 6 4"/>',
    trend:'<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
    doc:'<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>',
    list:'<line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>',
    sliders:'<line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>',
    plug:'<path d="M9 2v6M15 2v6"/><path d="M8 8h8v3a4 4 0 0 1-8 0z"/><path d="M12 15v5"/>',
    refresh:'<polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>',
    flow:'<circle cx="5" cy="6" r="2.5"/><circle cx="5" cy="18" r="2.5"/><circle cx="19" cy="12" r="2.5"/><path d="M7.3 7.1 16.7 11M7.3 16.9 16.7 13"/>',
    history:'<path d="M3 3v5h5"/><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/><path d="M12 7v5l3 2"/>',
  };
%>
<nav class="worknav">
  <% if(inConfigure){ %>
    <div class="wn-group">
      <div class="wn-label">Configure</div>
      <% cfgItems.forEach(function(c){ var on = c.tab ? (active===c.tab) : (active==='setup' && section===c.sec); var href = c.tab ? ('/process/'+proc.slug+'/'+c.tab) : ('/process/'+proc.slug+'/setup?section='+c.sec); %>
        <a class="wn-item cfg <%= on?'on':'' %>" href="<%= href %>">
          <span class="wn-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><%- ic[c.icon] %></svg></span>
          <span><%= c.label %></span>
        </a>
      <% }) %>
      <a class="wn-item wn-switch" href="/processes">
        <span class="wn-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></span>
        <span>Back to Command Center</span>
      </a>
    </div>
  <% } else { %>
    <div class="wn-group">
      <div class="wn-label">Manage</div>
      <% opItems.forEach(function(o){ var on = (active===o.tab); %>
        <a class="wn-item op <%= on?'on':'' %>" href="/process/<%= proc.slug %>/<%= o.tab %><%= run?('?run='+run.id):'' %>">
          <span class="wn-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><%- ic[o.icon] %></svg></span>
          <span><%= o.label %></span>
          <% if(o.tab==='monitor' && needsYou){ %><span class="wn-badge"></span><% } %>
        </a>
      <% }) %>
      <a class="wn-item wn-switch" href="/processes">
        <span class="wn-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></span>
        <span>Back to Command Center</span>
      </a>
    </div>
  <% } %>
</nav>
