generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─────────────────────────── AI AGENT SYSTEM ───────────────────────────

enum LlmProvider {
  openai
  anthropic
  google
}

enum MessageRole {
  user
  assistant
  system
  tool
}

enum AgentDocType {
  soul
  memory
  context
  daily
  build_log
  run_summary
}

enum CapabilityType {
  bundled
  external
}

model Agent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(100)
  description  String   @db.Text
  instructions String   @db.Text
  defaultModel String?  @map("default_model") @db.VarChar(100)
  features     Json     @default("{}")
  branding     Json     @default("{}")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  conversations     Conversation[]
  agentDocuments    AgentDocument[]
  memoryEmbeddings  AgentMemoryEmbedding[]
  kbDocuments       KBDocument[]
  kbDocumentChunks  KBDocumentChunk[]
  agentCapabilities AgentCapability[]
  ownedProcesses    Process[]             @relation("ProcessOwnerAgent")

  @@map("agents")
}

model Conversation {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicId      String    @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  agentId       String    @map("agent_id") @db.Uuid
  sessionToken  String?   @map("session_token") @db.VarChar(255)
  title         String?   @db.VarChar(255)
  messageCount  Int       @default(0) @map("message_count")
  lastMessageAt DateTime? @map("last_message_at") @db.Timestamptz()
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([agentId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String      @map("conversation_id") @db.Uuid
  role           MessageRole
  content        String      @db.Text
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model AgentDocument {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId   String       @map("agent_id") @db.Uuid
  docType   AgentDocType @map("doc_type")
  docKey    String       @map("doc_key") @db.VarChar(255)
  content   String       @db.Text
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  agent      Agent                  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  embeddings AgentMemoryEmbedding[]

  @@unique([agentId, docType, docKey])
  @@index([agentId])
  @@map("agent_documents")
}

model AgentMemoryEmbedding {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  docId       String  @map("doc_id") @db.Uuid
  agentId     String  @map("agent_id") @db.Uuid
  chunkText   String  @map("chunk_text") @db.Text
  embedding   Unsupported("vector(1536)")?
  lineStart   Int?    @map("line_start")
  lineEnd     Int?    @map("line_end")
  contentHash String? @map("content_hash") @db.VarChar(64)

  document AgentDocument @relation(fields: [docId], references: [id], onDelete: Cascade)
  agent    Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([docId])
  @@index([agentId])
  @@map("agent_memory_embeddings")
}

model KBDocument {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId    String   @map("agent_id") @db.Uuid
  name       String   @db.VarChar(500)
  sourceType String   @default("text") @map("source_type") @db.VarChar(50)
  content    String?  @db.Text
  metadata   Json     @default("{}")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  agent  Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  chunks KBDocumentChunk[]

  @@index([agentId])
  @@map("kb_documents")
}

model KBDocumentChunk {
  id         String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String                      @map("document_id") @db.Uuid
  agentId    String                      @map("agent_id") @db.Uuid
  chunkIndex Int                         @map("chunk_index")
  content    String                      @db.Text
  embedding  Unsupported("vector(1536)")?
  tokenCount Int?                        @map("token_count")

  document KBDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  agent    Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([agentId])
  @@map("kb_document_chunks")
}

model Capability {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String         @db.VarChar(255)
  slug        String         @unique @db.VarChar(100)
  description String?        @db.Text
  type        CapabilityType @default(bundled)
  serverUrl   String?        @map("server_url")
  config      Json           @default("{}")
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  agentCapabilities AgentCapability[]

  @@map("capabilities")
}

model AgentCapability {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId      String   @map("agent_id") @db.Uuid
  capabilityId String   @map("capability_id") @db.Uuid
  config       Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  agent      Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@unique([agentId, capabilityId])
  @@map("agent_capabilities")
}

model LlmConfig {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider  LlmProvider
  model     String      @db.VarChar(100)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("llm_configs")
}

model LlmApiKey {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider     LlmProvider
  encryptedKey String      @map("encrypted_key") @db.Text
  keyPrefix    String?     @map("key_prefix") @db.VarChar(20)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([provider])
  @@map("llm_api_keys")
}

model PlatformSetting {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key            String   @unique @db.VarChar(100)
  encryptedValue String   @map("encrypted_value") @db.Text
  keyPrefix      String?  @map("key_prefix") @db.VarChar(20)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("platform_settings")
}

// ─────────────────────────── FINANCE OS — ACCRUALS ───────────────────────────

enum Carrier {
  peak
  heartland
  coastal
}

enum RunStatus {
  draft
  processing
  awaiting_human
  needs_review
  approved
  posted
  reconciled
  blocked
}

enum RunMode {
  auto
  adhoc
  manual
}

enum DecisionType {
  policy_based
  judgment_based
  mixed
}

enum StepStatus {
  pending
  running
  done
  awaiting_human
  skipped
  error
}

enum ToolType {
  skill
  mcp
  agent
  human
  prompt
  automation
}

enum PolicyScope {
  org
  function
  process
  step
}

enum ExceptionSeverity {
  info
  warning
  critical
}

// DATA plane — raw + normalized shipment activity
model Shipment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId      String   @map("shipment_id") @db.VarChar(50)
  date            DateTime @db.Date
  originCity      String?  @map("origin_city") @db.VarChar(120)
  originState     String?  @map("origin_state") @db.VarChar(10)
  destCity        String?  @map("dest_city") @db.VarChar(120)
  destState       String?  @map("dest_state") @db.VarChar(10)
  destZip         String?  @map("dest_zip") @db.VarChar(10)
  carrierRaw      String   @map("carrier_raw") @db.VarChar(120)
  carrier         Carrier
  serviceLevelRaw String?  @map("service_level_raw") @db.VarChar(50)
  serviceLevel    String?  @map("service_level") @db.VarChar(50)
  weightLbs       Float?   @map("weight_lbs")
  weightEstimated Boolean  @default(false) @map("weight_estimated")
  units           Int?
  residential     Boolean  @default(false)
  specialHandling String?  @map("special_handling") @db.VarChar(255)
  period          String   @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([carrier])
  @@index([period])
  @@map("shipments")
}

// Versioned rate cards stored as parsed config (rate-card-as-config principle)
model RateCard {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  carrier   Carrier
  version   Int      @default(1)
  effective DateTime @db.Date
  data      Json
  isActive  Boolean  @default(true) @map("is_active")
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([carrier, version])
  @@map("rate_cards")
}

// Historical invoice line items (Oct 2025 – Mar 2026)
model Invoice {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId         String   @map("invoice_id") @db.VarChar(50)
  carrier           Carrier
  invoiceDate       DateTime @map("invoice_date") @db.Date
  serviceMonth      String   @map("service_month") @db.VarChar(20)
  shipmentRef       String?  @map("shipment_ref") @db.VarChar(50)
  destCity          String?  @map("dest_city") @db.VarChar(120)
  destState         String?  @map("dest_state") @db.VarChar(10)
  destZip           String?  @map("dest_zip") @db.VarChar(10)
  weightLbs         Float?   @map("weight_lbs")
  baseCharge        Float    @map("base_charge")
  fuelSurcharge     Float    @map("fuel_surcharge")
  accessorialFees   Float    @map("accessorial_fees")
  accessorialDetail String?  @map("accessorial_detail") @db.VarChar(255)
  adjustments       Float    @default(0)
  totalCharge       Float    @map("total_charge")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([carrier])
  @@index([serviceMonth])
  @@map("invoices")
}

// Baseline to beat — Denise's trailing 3-month average vs actuals
model DeniseBaseline {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  month           String  @db.VarChar(20)
  carrier         Carrier
  accrualEstimate Float   @map("accrual_estimate")
  actualInvoiced  Float   @map("actual_invoiced")
  varianceDollars Float   @map("variance_dollars")
  variancePct     Float   @map("variance_pct")
  notes           String? @db.Text

  @@map("denise_baseline")
}

// EXECUTION plane — a process run for a period (generic Run; accrual fields kept)
model AccrualRun {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  processId    String?   @map("process_id") @db.Uuid
  period       String    @db.VarChar(20)
  mode         RunMode   @default(manual)
  status       RunStatus @default(draft)
  frozen       Boolean   @default(false)
  parentRunId  String?   @map("parent_run_id") @db.Uuid
  pinnedVersions Json    @default("{}") @map("pinned_versions")
  totalAccrual Float     @default(0) @map("total_accrual")
  summary      Json      @default("{}")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  process    Process?    @relation(fields: [processId], references: [id])
  parent     AccrualRun? @relation("RunLineage", fields: [parentRunId], references: [id])
  children   AccrualRun[] @relation("RunLineage")
  lines      AccrualLine[]
  exceptions Exception[]
  events     LedgerEvent[]
  steps      StepExecution[]
  reconciliations Reconciliation[]
  actionItems ActionItem[]

  @@index([period])
  @@index([processId])
  @@map("accrual_runs")
}

// Per-shipment computed cost with full auditable breakdown
model AccrualLine {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId           String   @map("run_id") @db.Uuid
  shipmentId      String   @map("shipment_id") @db.VarChar(50)
  carrier         Carrier
  baseCharge      Float    @map("base_charge")
  fuelSurcharge   Float    @map("fuel_surcharge")
  accessorialFees Float    @map("accessorial_fees")
  total           Float
  breakdown       Json
  flags           Json     @default("[]")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  run AccrualRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("accrual_lines")
}

// CONTROLS — exception queue (assumptions made, anomalies flagged)
model Exception {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId      String?           @map("run_id") @db.Uuid
  shipmentId String?           @map("shipment_id") @db.VarChar(50)
  type       String            @db.VarChar(80)
  severity   ExceptionSeverity @default(warning)
  message    String            @db.Text
  resolved   Boolean           @default(false)
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  run AccrualRun? @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("exceptions")
}

// CONTROLS — per-item action queue: each must be cleared (approved or N/A) to sign off
model ActionItem {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId     String    @map("run_id") @db.Uuid
  kind      String    @db.VarChar(40)
  severity  String    @default("warning") @db.VarChar(20)
  title     String    @db.Text
  detail    String?   @db.Text
  amount    Float?
  status    String    @default("open") @db.VarChar(20) // open | approved | na
  note      String?   @db.Text
  clearedBy String?   @map("cleared_by") @db.VarChar(80)
  clearedAt DateTime? @map("cleared_at") @db.Timestamptz()
  ord       Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  run AccrualRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("action_items")
}

// CONTROLS — append-only event ledger (system of record)
model LedgerEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId     String?  @map("run_id") @db.Uuid
  actor     String   @db.VarChar(80)
  action    String   @db.VarChar(120)
  detail    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  run AccrualRun? @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("ledger_events")
}

// LEARN plane — actuals reconciliation
model Reconciliation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId       String?  @map("run_id") @db.Uuid
  period      String   @db.VarChar(20)
  carrier     Carrier
  estimated   Float
  actual      Float
  variance    Float
  variancePct Float    @map("variance_pct")
  detail      Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  run AccrualRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@map("reconciliations")
}

// LEARN plane — recursive self-improvement proposals
model ImprovementProposal {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId     String?  @map("run_id") @db.Uuid
  period    String   @db.VarChar(20)
  lever     String   @default("policy") @db.VarChar(20)
  component String   @db.VarChar(120)
  diagnosis String   @db.Text
  proposal  String   @db.Text
  riskLevel String   @default("low") @map("risk_level") @db.VarChar(20)
  status    String   @default("pending") @db.VarChar(20)
  target    Json     @default("{}")
  appliedVersionId String? @map("applied_version_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("improvement_proposals")
}

// ─────────────────────── FINANCE OS — PROCESS MODEL ───────────────────────
// Generalized layer: Org hierarchy ▸ Process ▸ Steps/Policies/Tools ▸ Runs ▸ StepExecutions.
// The freight accrual is the first Process loaded onto this model.

model Organization {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  legalEntities LegalEntity[]
  processes     Process[]

  @@map("organizations")
}

model LegalEntity {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String   @db.VarChar(255)
  code      String?  @db.VarChar(40)
  currency  String   @default("USD") @db.VarChar(8)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  org            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  businessUnits  BusinessUnit[]
  processes      Process[]

  @@index([orgId])
  @@map("legal_entities")
}

model BusinessUnit {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legalEntityId String   @map("legal_entity_id") @db.Uuid
  name          String   @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
  processes   Process[]

  @@index([legalEntityId])
  @@map("business_units")
}

model OrgFunction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(120)
  slug      String   @unique @db.VarChar(80)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  processes Process[]

  @@map("org_functions")
}

model Process {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  legalEntityId  String   @map("legal_entity_id") @db.Uuid
  businessUnitId String?  @map("business_unit_id") @db.Uuid
  functionId     String?  @map("function_id") @db.Uuid
  agentId        String?  @map("agent_id") @db.Uuid
  name           String   @db.VarChar(255)
  slug           String   @db.VarChar(120)
  description    String?  @db.Text
  frequency      String   @default("monthly") @db.VarChar(40)
  mode           RunMode  @default(manual)
  improveTrigger Json     @default("{}") @map("improve_trigger")
  version        Int      @default(1)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  legalEntity  LegalEntity   @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
  businessUnit BusinessUnit? @relation(fields: [businessUnitId], references: [id])
  function     OrgFunction?  @relation(fields: [functionId], references: [id])
  ownerAgent   Agent?        @relation("ProcessOwnerAgent", fields: [agentId], references: [id])
  steps        Step[]
  policies     Policy[]
  tools        ProcessTool[]
  runs         AccrualRun[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("processes")
}

model Step {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  processId   String       @map("process_id") @db.Uuid
  order       Int
  key         String       @db.VarChar(60)
  name        String       @db.VarChar(160)
  description String?      @db.Text
  decisionType DecisionType @default(policy_based) @map("decision_type")
  engineSource String?     @map("engine_source") @db.VarChar(120)
  toolId      String?      @map("tool_id") @db.Uuid
  isGate      Boolean      @default(false) @map("is_gate")
  pauseAfter  Boolean      @default(false) @map("pause_after")
  dependsOn   String[]     @default([]) @map("depends_on")
  feedbackTo  String?      @map("feedback_to") @db.VarChar(60)
  version     Int          @default(1)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  process    Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  tool       Tool?   @relation(fields: [toolId], references: [id])
  stepTools  StepTool[]
  policies   Policy[]
  executions StepExecution[]

  @@unique([processId, key])
  @@index([processId])
  @@map("steps")
}

model Policy {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  processId   String      @map("process_id") @db.Uuid
  stepId      String?     @map("step_id") @db.Uuid
  scope       PolicyScope @default(process)
  key         String      @db.VarChar(80)
  name        String      @db.VarChar(160)
  definition  String?     @db.Text
  params      Json        @default("{}")
  version     Int         @default(1)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  process Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  step    Step?   @relation(fields: [stepId], references: [id])

  @@unique([processId, key])
  @@index([processId])
  @@map("policies")
}

// Reusable global tool registry (skill/mcp/agent/human/prompt), mapped per-process.
model Tool {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        ToolType
  name        String   @db.VarChar(160)
  slug        String   @unique @db.VarChar(120)
  description String?  @db.Text
  config      Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  processTools ProcessTool[]
  steps        Step[]
  stepTools    StepTool[]

  @@map("tools")
}

// Per-step tool attachment — a step draws many tools (automations, agents,
// prompts, integrations) from the shared registry. This replaces the single
// Step.toolId pointer with a true many-to-many so a step can list every tool
// (and the "engine" automation) it runs on.
model StepTool {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stepId    String   @map("step_id") @db.Uuid
  toolId    String   @map("tool_id") @db.Uuid
  role      String?  @db.VarChar(80)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  step Step @relation(fields: [stepId], references: [id], onDelete: Cascade)
  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([stepId, toolId])
  @@index([stepId])
  @@map("step_tools")
}

model ProcessTool {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  processId String   @map("process_id") @db.Uuid
  toolId    String   @map("tool_id") @db.Uuid
  role      String?  @db.VarChar(80)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  process Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  tool    Tool    @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([processId, toolId])
  @@map("process_tools")
}

// Per-step execution record within a run — the auditable spine.
model StepExecution {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId          String       @map("run_id") @db.Uuid
  stepId         String?      @map("step_id") @db.Uuid
  order          Int
  key            String       @db.VarChar(60)
  name           String       @db.VarChar(160)
  status         StepStatus   @default(pending)
  decisionType   DecisionType @default(policy_based) @map("decision_type")
  input          Json         @default("{}")
  processing     Json         @default("{}")
  policiesApplied Json        @default("[]") @map("policies_applied")
  outcome        Json         @default("{}")
  override       Json?
  startedAt      DateTime?    @map("started_at") @db.Timestamptz()
  finishedAt     DateTime?    @map("finished_at") @db.Timestamptz()
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  run  AccrualRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  step Step?      @relation(fields: [stepId], references: [id])

  @@index([runId])
  @@map("step_executions")
}

// Versioning ledger — every object change (policy/step/tool) writes a version with diff.
model ObjectVersion {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  objectType String   @map("object_type") @db.VarChar(40)
  objectId   String   @map("object_id") @db.Uuid
  version    Int
  diff       Json     @default("{}")
  source     String   @default("manual") @db.VarChar(40)
  approvedBy String?  @map("approved_by") @db.VarChar(120)
  approvedAt DateTime? @map("approved_at") @db.Timestamptz()
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([objectType, objectId])
  @@map("object_versions")
}
